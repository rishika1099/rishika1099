# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# editor / tooling (keep out of the public repo)
.claude/
CLAUDE.md
AGENTS.md

# private poems — keep real poem text out of the PUBLIC repo (served only behind the gate locally / on a private source)
portfolio/src/content/poems/*.md
!portfolio/src/content/poems/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

# private photos — keep real photos out of the PUBLIC repo
portfolio/public/photos/*
!portfolio/public/photos/.gitkeep

# generated poem art — derived from confidential poems, kept off the PUBLIC repo
portfolio/public/poem-art/*.png

# derived poem metadata (moods etc.) — keep private like the poems
portfolio/src/content/poems/*.json

# about-page overrides edited via the secret /edit room (private, lives in Blobs on deploy)
portfolio/src/content/about-overrides.json
portfolio/src/content/copy-overrides.json
portfolio/src/content/copy-baseline.json
portfolio/src/content/blog-rich/
portfolio/src/content/project-overrides.json
portfolio/src/content/blog-overrides.json
portfolio/src/content/contact-links.json
portfolio/src/content/files/
